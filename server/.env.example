# Copy to .env (gitignored) for local dev, or to /etc/initech.env on the server
# (root:initech, 0640). All three vars are required.

APP_PASSWORD=your-password-here
JWT_SECRET=                       # openssl rand -hex 32
GEMINI_KEY=                       # from https://aistudio.google.com/apikey

# Optional
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
